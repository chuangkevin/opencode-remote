# Public app URL. Required for Web Push and PWA deep links in production.
APP_BASE_URL=https://remote.example.ts.net

# Server
PORT=9223
DATABASE_PATH=./data/opencode-remote.db
RUNNER_SHARED_TOKEN=change-this-runner-token
SSE_HEARTBEAT_MS=15000
NATIVE_OPENCODE_URL=http://127.0.0.1:4296
NATIVE_OPENCODE_USERNAME=opencode
NATIVE_OPENCODE_PASSWORD=opencode
NATIVE_OPENCODE_PUBLIC_PORT=4296
DISPATCH_DIRECTORY=D:\Projects\_HomeProject
DISPATCH_TITLE=Dispatch

# Runner
DISPATCH_SERVER_URL=http://localhost:9223
RUNNER_POLL_INTERVAL_MS=3000
RUNNER_LEASE_MS=15000
RUNNER_EXECUTION_MODE=stub
RUNNER_STUB_DELAY_MS=1500
RUNNER_REQUEST_TIMEOUT_MS=15000

# OpenCode bridge (future real executor mode)
OPENCODE_SERVER_URL=http://127.0.0.1:4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
OPENCODE_DIRECTORY=

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:kevin@example.com
